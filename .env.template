# ============================================================
#  biAjans — AI Marketing & Social Media OS
#  Yapılandırma Şablonu
#  Bu dosyayı '.env' olarak kopyalayın ve değerleri doldurun.
#  .env dosyasını asla Git'e göndermeyin!
# ============================================================


# ─── AI İçerik Üretimi ──────────────────────────────────────
# Google Gemini API Key → https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (DALL-E 3 görsel üretimi) → https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here


# ─── Uygulama Ayarları ──────────────────────────────────────
# Yerel geliştirme için: http://localhost:8000
# Canlı sunucu için: https://your-domain.com
APP_BASE_URL=http://localhost:8000

# Oturum şifreleme anahtarı — canlıya geçmeden mutlaka değiştirin!
APP_SECRET_KEY=biajans-super-secret-change-in-production


# ─── Meta (Facebook · Instagram · Threads · WhatsApp · Meta Ads) ───
# Uygulama oluşturun: https://developers.facebook.com/apps/
# Gerekli izinler: pages_read_engagement, instagram_basic,
#                  instagram_content_publish, ads_read, whatsapp_business_management
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here


# ─── Google (YouTube · Google Ads · Looker Studio) ──────────
# Proje oluşturun: https://console.cloud.google.com/apis/credentials
# Etkinleştirin: YouTube Data API v3, YouTube Analytics API, Google Ads API
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here


# ─── LinkedIn ───────────────────────────────────────────────
# Uygulama oluşturun: https://www.linkedin.com/developers/apps
# Gerekli ürünler: Share on LinkedIn, Marketing Developer Platform
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here


# ─── X (Twitter) ────────────────────────────────────────────
# Developer portalı: https://developer.x.com/en/portal/dashboard
# OAuth 2.0 + PKCE etkinleştirin, User Auth Settings'i yapılandırın
X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here


# ─── TikTok ─────────────────────────────────────────────────
# Geliştirici portalı: https://developers.tiktok.com/
# Dikkat: Uygulama incelemesi gerektirir (3-5 iş günü)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here


# ─── Pinterest ──────────────────────────────────────────────
# Uygulama oluşturun: https://developers.pinterest.com/apps/
PINTEREST_APP_ID=your_pinterest_app_id_here
PINTEREST_APP_SECRET=your_pinterest_app_secret_here


# ─── Bluesky (AT Protocol) ──────────────────────────────────
# OAuth değil, Uygulama Şifresi (App Password) kullanır
# Şifre oluşturun: https://bsky.app/settings/app-passwords
BLUESKY_IDENTIFIER=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
